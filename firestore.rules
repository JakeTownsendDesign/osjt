rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }

    // Today's date as YYYY-MM-DD, derived from the server clock (request.time)
    function todayStr() {
      return string(request.time.year()) + '-'
        + (request.time.month() < 10 ? '0' : '') + string(request.time.month()) + '-'
        + (request.time.day() < 10 ? '0' : '') + string(request.time.day());
    }

    function albumOwner(albumId) {
      return get(/databases/$(database)/documents/albums/$(albumId)).data.createdBy;
    }

    // The set of fields changed by an update
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Album must not exceed its capacity after this write
    function withinCapacity(albumId) {
      let album = get(/databases/$(database)/documents/albums/$(albumId)).data;
      let afterCount = getAfter(/databases/$(database)/documents/albums/$(albumId)).data.photoCount;
      return afterCount <= album.maxPhotos;
    }

    // Validate the daily contribution counter for a post in a NON-owned album.
    // The post create must be accompanied (same batched write) by an update to
    // users/{uid}.dailyContrib that increments today's count and stays <= 3.
    function withinDailyLimit() {
      let beforeData = get(/databases/$(database)/documents/users/$(uid())).data;
      let startedToday = 'dailyContrib' in beforeData
        && beforeData.dailyContrib.date == todayStr();
      let after = getAfter(/databases/$(database)/documents/users/$(uid())).data.dailyContrib;
      return after.date == todayStr()
        && after.count is int
        && after.count >= 1
        && after.count <= 3
        && (startedToday
              ? after.count == beforeData.dailyContrib.count + 1
              : after.count == 1);
    }

    // ── users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      // A user may only create/update their own profile doc (incl. dailyContrib)
      allow create, update: if isSignedIn() && userId == uid();
      allow delete: if false;
    }

    // ── usernames (reservations) ───────────────────────────────────────────
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── albums ─────────────────────────────────────────────────────────────
    match /albums/{albumId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == uid();
      // Owner may edit anything. Anyone else may only touch the denormalised
      // counter/preview fields (set when contributing, liking, commenting).
      allow update: if isSignedIn() && (
        resource.data.createdBy == uid()
        || changedKeys().hasOnly([
             'photoCount', 'score', 'likeCount', 'commentCount',
             'contributorCount', 'thumbnailURLs', 'status', 'updatedAt'
           ])
      );
      allow delete: if isSignedIn() && resource.data.createdBy == uid();
    }

    // ── posts ──────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isSignedIn();

      // Create: never exceed album capacity. Own album → allowed; other
      // albums → daily contribution limit enforced.
      allow create: if isSignedIn()
        && request.resource.data.createdBy == uid()
        && withinCapacity(request.resource.data.albumId)
        && (
          albumOwner(request.resource.data.albumId) == uid()
          || withinDailyLimit()
        );

      // Post owner may edit caption; anyone may change only the like count.
      allow update: if isSignedIn() && (
        resource.data.createdBy == uid()
        || changedKeys().hasOnly(['likeCount'])
      );

      // Post owner or the album owner may delete
      allow delete: if isSignedIn() && (
        resource.data.createdBy == uid()
        || albumOwner(resource.data.albumId) == uid()
      );
    }

    // ── likes (one per post per user) ───────────────────────────────────────
    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth != null
        && (request.resource == null || request.resource.data.userId == uid()
            || resource.data.userId == uid());
    }

    // ── comments ─────────────────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == uid();
      // Only the like count may change on an existing comment.
      allow update: if isSignedIn() && changedKeys().hasOnly(['likeCount']);
      // Comment owner or the album owner may delete
      allow delete: if isSignedIn() && (
        resource.data.createdBy == uid()
        || albumOwner(resource.data.albumId) == uid()
      );
    }

    // ── commentLikes ─────────────────────────────────────────────────────────
    match /commentLikes/{id} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn();
    }

    // ── follows ──────────────────────────────────────────────────────────────
    match /follows/{id} {
      allow read: if isSignedIn();
      // A user may only create/remove their own follow edges
      allow create: if isSignedIn() && request.resource.data.followerId == uid();
      allow delete: if isSignedIn() && resource.data.followerId == uid();
    }

    // ── reports ──────────────────────────────────────────────────────────────
    match /reports/{id} {
      allow read: if false; // admin-only, via console for now
      allow create: if isSignedIn() && request.resource.data.reportedBy == uid();
    }

    // ── seed pre-flight ping ──────────────────────────────────────────────────
    match /_ping/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
