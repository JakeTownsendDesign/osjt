rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos — only the owner may write
    match /avatars/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Album post photos — any signed-in user may upload
    match /posts/{albumId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
